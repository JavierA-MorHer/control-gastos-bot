# Configuración de Base de Datos (Neon PostgreSQL)
# Reemplaza con tu URL de conexión proporcionada por Neon
NEON_DATABASE_URL=postgresql://usuario:contraseña@servidor.neon.tech/nombre_bd?sslmode=require

# Credenciales de Twilio
# Encuentra estos valores en la consola principal de Twilio
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=tu_token_secreto_aqui
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
OPENAI_API_KEY=sk-tu_api_key_de_openai
